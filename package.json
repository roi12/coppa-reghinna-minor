{
  "name": "sports-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:base": "node prisma/seed-base.mjs",
    "db:seed:demo": "node prisma/seed.mjs",
    "db:seed:production": "node prisma/seed-production.mjs",
    "db:reset:local": "node scripts/reset-local-development.mjs",
    "seed:test-registrations": "node scripts/seed-test-registrations.mjs",
    "db:test:ensure": "node scripts/provision-test-database.mjs",
    "test:integration:tournament": "tsx --test tests/integration/tournament-31-match-flow.test.ts",
    "smoke:test": "node scripts/smoke-test.mjs",
    "test:unit": "tsx --test src/features/*/server/*.test.ts",
    "test:e2e": "npm run db:seed:demo && playwright test",
    "test:e2e:ui": "npm run db:seed:demo && playwright test --ui",
    "check": "npx tsc --noEmit && npm run lint && npm run test:unit && npm run build",
    "check:db": "npx prisma validate && npx prisma migrate status && npx prisma generate",
    "check:prod-safety": "node scripts/check-production-safety.mjs"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "next": "16.2.6",
    "nodemailer": "^8.0.11",
    "pg": "^8.16.3",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
