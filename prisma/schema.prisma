generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  COMPLETED
}

enum TournamentFormat {
  ROUND_ROBIN
  KNOCKOUT
  GROUPS_PLUS_KNOCKOUT
  SINGLE_ROUND_ROBIN
  DOUBLE_ROUND_ROBIN
  GROUPS_ONLY
  GROUPS_THEN_KNOCKOUT
  KNOCKOUT_ONLY
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchScoreEventActionType {
  START_MATCH
  FINISH_MATCH
  RETURN_TO_SCHEDULED
  REOPEN_MATCH
  POSTPONE_MATCH
  CANCEL_MATCH
  INCREMENT_HOME_SCORE
  INCREMENT_AWAY_SCORE
  DECREMENT_HOME_SCORE
  DECREMENT_AWAY_SCORE
  SET_SCORE
  UNDO_LAST_CHANGE
}

enum TournamentStageType {
  GROUP_STAGE
  KNOCKOUT_STAGE
}

enum KnockoutRound {
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
  THIRD_PLACE
}

enum MatchParticipantSourceType {
  DIRECT_TEAM
  GROUP_POSITION
  MATCH_WINNER
  MATCH_LOSER
}

enum TeamRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TeamRegistrationPlayerDocumentStatus {
  MISSING
  UPLOADED
  PAPER_DELIVERY
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

model Organization {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tournaments Tournament[]
  teams     Team[]
  players   Player[]

  @@index([slug])
}

model Tournament {
  id            String           @id @default(cuid())
  organizationId String
  name          String
  slug          String           @unique
  sport         String
  seasonLabel   String
  locationLabel String?
  format        TournamentFormat @default(ROUND_ROBIN)
  status        TournamentStatus @default(DRAFT)
  expectedTeamCount Int?
  startsAt      DateTime?
  endsAt        DateTime?
  scheduleStartDate DateTime?
  scheduleMaxMatchesPerDay Int?
  scheduleMinimumRestDays Int? @default(0)
  publishedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams         TournamentTeam[]
  groups        TournamentGroup[]
  stages        TournamentStage[]
  scheduleSlots TournamentScheduleSlot[]
  matches       Match[]
  registrations TeamRegistration[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model Team {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  players        Player[]
  tournaments    TournamentTeam[]
  registrations  TeamRegistration[]
  homeMatches    Match[]          @relation("MatchHomeTeam")
  awayMatches    Match[]          @relation("MatchAwayTeam")
  homeSourceMatches Match[]       @relation("MatchHomeSourceTeam")
  awaySourceMatches Match[]       @relation("MatchAwaySourceTeam")

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  groupId      String?
  groupSlot    Int?
  seed         Int?
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  group        TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, teamId])
  @@index([teamId])
  @@index([groupId])
  @@index([tournamentId, groupId])
  @@unique([groupId, groupSlot])
}

model TournamentStage {
  id                    String              @id @default(cuid())
  tournamentId          String
  order                 Int
  type                  TournamentStageType
  name                  String
  isPublic              Boolean             @default(true)
  groupCount            Int?
  teamsPerGroup         Int?
  legs                  Int?
  qualifiersPerGroup    Int?
  knockoutTeamCount     Int?
  knockoutRound         KnockoutRound?
  includeThirdPlaceMatch Boolean?
  stageBreakDaysAfter   Int?                @default(0)
  configuration         Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  tournament            Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groups                TournamentGroup[]
  matches               Match[]

  @@index([tournamentId, order])
  @@unique([tournamentId, order])
}

model TournamentGroup {
  id           String           @id @default(cuid())
  tournamentId String
  stageId      String?
  name         String
  sequence     Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  stage        TournamentStage? @relation(fields: [stageId], references: [id], onDelete: Cascade)
  teams        TournamentTeam[]
  matches      Match[]
  homeSourceMatches Match[]     @relation("MatchHomeSourceGroup")
  awaySourceMatches Match[]     @relation("MatchAwaySourceGroup")

  @@index([tournamentId])
  @@index([stageId])
  @@unique([tournamentId, name])
  @@unique([tournamentId, sequence])
}

model TournamentScheduleSlot {
  id              String     @id @default(cuid())
  tournamentId    String
  sequence        Int
  startMinutes    Int
  durationMinutes Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@unique([tournamentId, sequence])
}

model Player {
  id             String        @id @default(cuid())
  organizationId String
  teamId         String?
  firstName      String
  lastName       String
  displayName    String?
  email          String?
  jerseyNumber   String?
  role           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([teamId])
}

model TeamRegistration {
  id               String                 @id @default(cuid())
  tournamentId     String
  teamId           String?
  captainFirstName String
  captainLastName  String
  captainEmail     String
  captainPhone     String
  teamName         String
  notes            String?
  captainManageTokenHash       String?    @unique
  captainManageTokenIssuedAt   DateTime?
  captainManageTokenLastUsedAt DateTime?
  captainManageTokenRevokedAt  DateTime?
  gdprDocumentFilePath         String?
  gdprDocumentFileName         String?
  gdprDocumentMimeType         String?
  gdprDocumentSizeBytes        Int?
  gdprDocumentUploadedAt       DateTime?
  gdprPaperDeliveryMarkedAt    DateTime?
  status           TeamRegistrationStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedByUserId String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  tournament       Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team             Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  reviewedBy       User?                  @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  players          TeamRegistrationPlayer[]

  @@index([tournamentId])
  @@index([tournamentId, status, createdAt])
  @@index([teamId])
  @@index([reviewedByUserId])
}

model TeamRegistrationPlayer {
  id                    String                               @id @default(cuid())
  registrationId        String
  firstName             String
  lastName              String
  jerseyNumber          String
  role                  String?
  sortOrder             Int
  documentStatus        TeamRegistrationPlayerDocumentStatus @default(MISSING)
  documentFilePath      String?
  documentFileName      String?
  documentMimeType      String?
  documentSizeBytes     Int?
  documentUploadedAt    DateTime?
  documentMarkedPaperAt DateTime?
  createdAt             DateTime                             @default(now())
  registration          TeamRegistration                     @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId, sortOrder])
  @@unique([registrationId, jerseyNumber])
}

model Match {
  id            String      @id @default(cuid())
  tournamentId  String
  stageId       String?
  groupId       String?
  sequence      Int?
  homeTeamId    String?
  awayTeamId    String?
  homeParticipantSourceType MatchParticipantSourceType?
  awayParticipantSourceType MatchParticipantSourceType?
  homeSourceTeamId String?
  awaySourceTeamId String?
  homeSourceGroupId String?
  awaySourceGroupId String?
  homeSourceGroupPosition Int?
  awaySourceGroupPosition Int?
  homeSourceMatchId String?
  awaySourceMatchId String?
  homeParticipantLocked Boolean @default(false)
  awayParticipantLocked Boolean @default(false)
  roundLabel    String?
  startsAt      DateTime?
  endsAt        DateTime?
  liveStartedAt DateTime?
  finishedAt    DateTime?
  lastScoreUpdatedAt DateTime?
  lastScoreUpdatedByUserId String?
  locationLabel String?
  status        MatchStatus @default(SCHEDULED)
  homeScore     Int         @default(0)
  awayScore     Int         @default(0)
  scoreVersion  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tournament    Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  stage         TournamentStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  group         TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  homeTeam      Team?       @relation("MatchHomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam      Team?       @relation("MatchAwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  homeSourceTeam Team?      @relation("MatchHomeSourceTeam", fields: [homeSourceTeamId], references: [id], onDelete: SetNull)
  awaySourceTeam Team?      @relation("MatchAwaySourceTeam", fields: [awaySourceTeamId], references: [id], onDelete: SetNull)
  homeSourceGroup TournamentGroup? @relation("MatchHomeSourceGroup", fields: [homeSourceGroupId], references: [id], onDelete: SetNull)
  awaySourceGroup TournamentGroup? @relation("MatchAwaySourceGroup", fields: [awaySourceGroupId], references: [id], onDelete: SetNull)
  homeSourceMatch Match?    @relation("MatchHomeSourceMatch", fields: [homeSourceMatchId], references: [id], onDelete: SetNull)
  awaySourceMatch Match?    @relation("MatchAwaySourceMatch", fields: [awaySourceMatchId], references: [id], onDelete: SetNull)
  lastScoreUpdatedBy User?  @relation("MatchLastScoreUpdatedBy", fields: [lastScoreUpdatedByUserId], references: [id], onDelete: SetNull)
  dependentHomeMatches Match[] @relation("MatchHomeSourceMatch")
  dependentAwayMatches Match[] @relation("MatchAwaySourceMatch")
  scoreEvents   MatchScoreEvent[]

  @@index([tournamentId])
  @@index([stageId])
  @@index([groupId])
  @@index([tournamentId, status])
  @@index([tournamentId, groupId])
  @@index([tournamentId, groupId, status])
  @@index([tournamentId, startsAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([homeSourceMatchId])
  @@index([awaySourceMatchId])
  @@index([lastScoreUpdatedByUserId])
}

model MatchScoreEvent {
  id                    String                    @id @default(cuid())
  matchId               String
  userId                String?
  actionType            MatchScoreEventActionType
  previousStatus        MatchStatus
  nextStatus            MatchStatus
  previousHomeScore     Int
  previousAwayScore     Int
  nextHomeScore         Int
  nextAwayScore         Int
  createdAt             DateTime                  @default(now())
  match                 Match                     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user                  User?                     @relation("MatchScoreEventUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt])
  @@index([userId])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  reviewedTeamRegistrations TeamRegistration[]
  matchScoreEvents MatchScoreEvent[] @relation("MatchScoreEventUser")
  lastScoreUpdatedMatches Match[] @relation("MatchLastScoreUpdatedBy")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
