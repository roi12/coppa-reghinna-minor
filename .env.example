# Required in all environments.
# Local PostgreSQL example:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/sports_platform?schema=public"

# Public application URL used for metadata, sitemap, and robots output.
# Set this to your deployed origin in production.
APP_URL="http://localhost:3000"

# Gmail SMTP settings for captain-facing MVP emails.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="coppareghinnaminor@gmail.com"
SMTP_PASSWORD=""
EMAIL_FROM="Coppa Reghinna Minor <coppareghinnaminor@gmail.com>"
EMAIL_REPLY_TO="coppareghinnaminor@gmail.com"

# Supabase Storage settings for private team document uploads.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_TEAM_DOCUMENTS_BUCKET="team-documents"

# Production-only seed variables for `npm run db:seed:production`.
PRODUCTION_OWNER_EMAIL="owner@example.com"
PRODUCTION_OWNER_NAME="Owner Coppa Reghinna Minor"
PRODUCTION_OWNER_PASSWORD="change-me-owner"
PRODUCTION_ADMIN_EMAIL="admin@example.com"
PRODUCTION_ADMIN_NAME="Admin Coppa Reghinna Minor"
PRODUCTION_ADMIN_PASSWORD="change-me-admin"

# Optional smoke-test settings for `npm run smoke:test`.
